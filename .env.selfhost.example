# HD-Search self-hosted stack — OPTIONAL config. Copy to `.env.selfhost` if you
# want to change any defaults, otherwise you can run with none of this set:
#
#   docker compose -f docker-compose.selfhost.yml up -d --build
#   # or, to override defaults:
#   cp .env.selfhost.example .env.selfhost   # edit, then:
#   docker compose --env-file .env.selfhost -f docker-compose.selfhost.yml up -d --build
#
# THERE ARE NO SECRETS IN THIS FILE — and that's deliberate:
#   • App crypto secrets (encryption / internal / session) are auto-generated on
#     first boot and persisted to a shared Docker volume. Nothing to paste.
#   • The bundled Postgres / SeaweedFS run on a private internal network and are
#     never exposed, so their credentials are fixed internal defaults (not here).
#   • Provider API keys (OpenAI, Brave, SerpAPI, …) are entered in the UI:
#       Account → Provider Keys        (per-user keys)
#       Dashboard → System Admin       (system-wide default keys, admin only)
#     Never put provider keys in env.

# ---- Published host ports (change if these clash with something already running) ----
WEB_PORT=3000
API_PORT=8791

# ---- Public URLs the browser uses (set to your host/IP if not localhost) ----
PUBLIC_API_URL=http://localhost:8791
APP_BASE_URL=http://localhost:3000

# ---- Optional behaviour ----
# Allow open self-service signup. Default: only the first-run admin can be created
# via the UI, then registration is closed.
# HDSEARCH_OPEN_SIGNUP=true
# Self-hosted maps geocoder (only with `--profile maps`):
# HDSEARCH_GEOCODER_URL=http://hds-photon:2322
# Set 1 if you have an NVIDIA GPU for the embeddings container:
# WEAVIATE_ENABLE_CUDA=0

# ---- Optional headless admin bootstrap ----
# Leave BOTH unset to create the admin through the first-run UI screen (recommended).
# Set both to create the admin non-interactively on first boot instead:
# HDSEARCH_ADMIN_EMAIL=admin@example.com
# HDSEARCH_ADMIN_PASSWORD=change-me-at-least-8-chars
